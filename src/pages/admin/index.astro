---
// 这里不需要任何 Astro 组件，我们直接加载 Decap CMS 的核心脚本
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>博客管理后台</title>
    <!-- 引入后台管理界面的样式 -->
    <link rel="stylesheet" href="https://unpkg.com/decap-cms@^3.0.0/dist/decap-cms.css" />
