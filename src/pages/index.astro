---
import '../styles/global.css';

const posts = Object.values(
  import.meta.glob('../content/posts/*.md', { eager: true })
);

const sortedPosts = [...posts].sort((a, b) => 
  new Date(b.frontmatter.date) - new Date(a.frontmatter.date)
);
---

<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="WY的记事本 - 个人研究博客，分享算法、数学等领域的学习笔记" />
    <meta name="keywords" content="博客, 算法, 数学, 研究, 学习笔记" />
    <meta name="author" content="WY" />
    <meta property="og:title" content="WY的记事本" />
    <meta property="og:description" content="WY的记事本 - 个人研究博客" />
    <meta property="og:type" content="website" />
    <title>WY的记事本</title>
  </head>

  <body class="min-h-screen bg-[#fefbf6]">
    <header class="bg-[#d4eaf7] border-b border-[#b8d4e8] px-8 py-5">
      <h1 class="text-2xl font-normal tracking-wide text-[#2a5a8a]">
        WY的记事本
      </h1>
    </header>

    <div class="flex min-h-[calc(100vh-72px)]">
      <aside class="w-64 flex-shrink-0 bg-[#d4eaf7] p-6 border-r border-[#b8d4e8]">
        <h2 class="text-lg font-normal text-[#2a5a8a] mb-4 pb-2 border-b border-[#b8d4e8]">
          目录
        </h2>
        <nav class="space-y-3">
          <a
            href="/"
            class="block text-[#3a7ab8] hover:text-[#1a5a98] transition-colors py-1"
          >
            首页
          </a>
          <a
            href="/tags/"
            class="block text-[#3a7ab8] hover:text-[#1a5a98] transition-colors py-1"
          >
            标签
          </a>
          {sortedPosts.map(post => {
            const slug = post.file.split('/').pop().replace('.md', '');
            return (
              <a
                href={`/posts/${slug}/`}
                class="block text-[#3a7ab8] hover:text-[#1a5a98] transition-colors py-1 leading-relaxed"
              >
                {post.frontmatter.title}
              </a>
            );
          })}
        </nav>
      </aside>

      <main class="flex-1 px-12 py-10">
        <div class="max-w-3xl">
          <header class="mb-10">
            <h2 class="text-4xl font-normal text-[#333] mb-3 tracking-wide">
              所有文章
            </h2>
            <p class="text-[#666] text-lg leading-relaxed">
              共 {posts.length} 篇
            </p>
          </header>

          <section class="space-y-6">
            {sortedPosts.map(post => {
              const slug = post.file.split('/').pop().replace('.md', '');
              return (
                <article class="group border-l-4 border-[#d4eaf7] pl-6 py-2 hover:border-[#3a7ab8] transition-colors">
                  <div class="text-sm text-[#888] mb-1">
                    {post.frontmatter.date}
                  </div>
                  <a
                    href={`/posts/${slug}/`}
                    class="text-2xl text-[#333] group-hover:text-[#2a5a8a] transition-colors leading-relaxed"
                  >
                    {post.frontmatter.title}
                  </a>
                  <div class="text-sm text-[#999] mt-2">
                    {post.frontmatter.tags?.join(' · ')}
                  </div>
                </article>
              );
            })}
          </section>
        </div>
      </main>
    </div>
  </body>
</html>
