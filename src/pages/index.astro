---
const posts = Object.values(
  import.meta.glob('./posts/*.md', { eager: true })
);

posts.sort((a, b) =>
  new Date(b.frontmatter.date) - new Date(a.frontmatter.date)
);
---

<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <title>gahs notes</title>
  </head>

  <body class="bg-[#fbfbfb] text-[#222]">

    <main class="max-w-3xl mx-auto px-6 py-12">

      <!-- Header -->
      <header class="mb-12">
        <h1 class="text-5xl font-semibold tracking-tight mb-2">
          gahs notes
        </h1>

        <p class="text-gray-500">
          Algorithms · Math · Thinking
        </p>

        <div class="mt-4 text-sm">
          <a href="/tags" class="text-blue-600 hover:underline">
            Tags
          </a>
        </div>
      </header>

      <!-- Posts -->
      <section class="space-y-8">

        {posts.map(post => (
          <div class="group">
            <div class="text-sm text-gray-500">
              {post.frontmatter.date}
            </div>

            <a
              href={post.url}
              class="text-2xl font-medium group-hover:text-blue-600 transition"
            >
              {post.frontmatter.title}
            </a>
          </div>
        ))}

      </section>

    </main>

  </body>
</html>