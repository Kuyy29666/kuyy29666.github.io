---
import '../styles/global.css';

const { frontmatter } = Astro.props;

const allPosts = Object.values(
  import.meta.glob('../content/posts/*.md', { eager: true })
);

const sortedPosts = [...allPosts].sort((a, b) => 
  new Date(b.frontmatter.date) - new Date(a.frontmatter.date)
);
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={frontmatter.description || 'WY的记事本 - 个人研究博客'} />
    <meta name="keywords" content={frontmatter.tags?.join(', ') || '博客, 技术, 研究'} />
    <meta name="author" content="WY" />
    <meta property="og:title" content={frontmatter.title} />
    <meta property="og:description" content={frontmatter.description || 'WY的记事本'} />
    <meta property="og:type" content="article" />
    <meta property="og:url" content={Astro.url} />
    <title>{frontmatter.title} - WY的记事本</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css"
    />
    <script
      defer
      src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.js"
    ></script>
    <script
      defer
      src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/contrib/auto-render.min.js"
    ></script>
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        renderMathInElement(document.body, {
          delimiters: [
            { left: '$$', right: '$$', display: true },
            { left: '$', right: '$', display: false },
          ],
          throwOnError: false,
        });
      });
    </script>
  </head>

  <body class="min-h-screen bg-[#fefbf6]">
    <header class="bg-[#d4eaf7] border-b border-[#b8d4e8] px-8 py-5">
      <a href="/" class="text-2xl font-normal tracking-wide text-[#2a5a8a] hover:text-[#1a5a98] transition-colors">
        WY的记事本
      </a>
    </header>

    <div class="flex min-h-[calc(100vh-72px)]">
      <aside class="w-64 flex-shrink-0 bg-[#d4eaf7] p-6 border-r border-[#b8d4e8]">
        <h2 class="text-lg font-normal text-[#2a5a8a] mb-4 pb-2 border-b border-[#b8d4e8]">
          目录
        </h2>
        <nav class="space-y-3">
          <a
            href="/"
            class="block text-[#3a7ab8] hover:text-[#1a5a98] transition-colors py-1"
          >
            返回首页
          </a>
          <a
            href="/tags/"
            class="block text-[#3a7ab8] hover:text-[#1a5a98] transition-colors py-1"
          >
            标签
          </a>
          <div class="border-t border-[#b8d4e8] my-4 pt-4">
            <div class="text-sm text-[#2a5a8a] mb-2">文章列表</div>
            {sortedPosts.map(post => {
              const slug = post.file.split('/').pop().replace('.md', '');
              const postUrl = `/posts/${slug}/`;
              return (
                <a
                  href={postUrl}
                  class:list={[
                    "block py-1 leading-relaxed transition-colors",
                    postUrl === Astro.url.pathname
                      ? "text-[#1a5a98] font-medium"
                      : "text-[#3a7ab8] hover:text-[#1a5a98]"
                  ]}
                >
                  {post.frontmatter.title}
                </a>
              );
            })}
          </div>
        </nav>
      </aside>

      <main class="flex-1 px-12 py-10">
        <article class="max-w-3xl">
          <header class="mb-10 pb-6 border-b border-[#e0e0e0]">
            <h1 class="text-4xl font-normal text-[#333] mb-4 tracking-wide leading-relaxed">
              {frontmatter.title}
            </h1>
            <div class="text-[#888] text-lg leading-relaxed">
              {frontmatter.date}
            </div>
            {frontmatter.tags && (
              <div class="text-[#999] text-base mt-3 leading-relaxed">
                {frontmatter.tags.join(' · ')}
              </div>
            )}
          </header>

          <div class="prose prose-lg max-w-none prose-headings:font-normal prose-headings:tracking-wide prose-p:leading-loose prose-li:leading-relaxed text-[#333]">
            <slot />
          </div>
        </article>
      </main>
    </div>
  </body>
</html>
