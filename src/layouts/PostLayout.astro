---
const { frontmatter } = Astro.props;
---

<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <title>{frontmatter.title}</title>

    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css"
    />

    <style>
      body {
        background: #f5f1e8;
        color: #2a2a2a;
        font-family:
          "Iowan Old Style",
          "Palatino Linotype",
          "Times New Roman",
          serif;

        margin: 0;
      }

      main {
        max-width: 760px;
        margin: auto;
        padding: 60px 32px;
      }

      h1 {
        font-size: 42px;
        margin-top: 40px;
      }

      h2 {
        margin-top: 50px;
      }

      article {
        line-height: 1.9;
        font-size: 18px;
      }

      a {
        color: #4a6fa5;
        text-decoration: none;
      }

      code {
        background: #ece7dc;
        padding: 2px 6px;
        border-radius: 6px;
      }

      pre {
        background: #ece7dc;
        padding: 18px;
        overflow-x: auto;
        border-radius: 12px;
      }
    </style>
  </head>

  <body>
    <main>
      <a href="/">← Home</a>

      <h1>{frontmatter.title}</h1>

      <article>
        <slot />
      </article>
    </main>
  </body>
</html>